{
  "name": "meta-kim",
  "version": "2.0.9",
  "description": "Governance layer for AI coding: meta agents, workflow contract, meta-theory; canonical in canonical/, with generated Claude/Codex/OpenClaw/Cursor projections.",
  "private": true,
  "type": "module",
  "scripts": {
    "meta:sync": "node scripts/sync-runtimes.mjs",
    "meta:check:runtimes": "node scripts/sync-runtimes.mjs --check",
    "meta:sync:global": "node scripts/sync-global-meta-theory.mjs",
    "meta:check:global": "node scripts/sync-global-meta-theory.mjs --check",
    "meta:show:global:targets": "node scripts/sync-global-meta-theory.mjs --print-targets",
    "discover:global": "node scripts/discover-global-capabilities.mjs",
    "meta:index:runs": "node scripts/run-index.mjs index",
    "meta:query:runs": "node scripts/run-index.mjs query",
    "meta:rebuild:run-index": "node scripts/run-index.mjs rebuild",
    "migrate:meta-kim": "node scripts/migrate-into-meta-kim.mjs",
    "meta:deps:install": "node scripts/install-global-skills-all-runtimes.mjs --targets claude",
    "meta:deps:update": "node scripts/install-global-skills-all-runtimes.mjs --update --targets claude",
    "meta:deps:install:all-runtimes": "node scripts/install-global-skills-all-runtimes.mjs",
    "meta:deps:update:all-runtimes": "node scripts/install-global-skills-all-runtimes.mjs --update",
    "meta:deps:install:claude-plugins": "node scripts/install-global-skills-all-runtimes.mjs --plugins-only",
    "meta:test:mcp": "node scripts/mcp/meta-runtime-server.mjs --self-test",
    "prepare:openclaw-local": "node scripts/prepare-openclaw-local.mjs",
    "meta:eval:agents": "node scripts/eval-meta-agents.mjs",
    "meta:eval:agents:live": "node scripts/eval-meta-agents.mjs --live",
    "meta:validate:run": "node scripts/validate-run-artifact.mjs",
    "meta:doctor": "node scripts/doctor-interactive.mjs",
    "meta:doctor:governance": "node scripts/doctor-governance.mjs",
    "meta:doctor:compaction": "node scripts/write-compaction.mjs",
    "meta:doctor:migration": "node scripts/write-migration.mjs",
    "prompt:next-iteration": "node scripts/prompt-next-iteration.mjs",
    "meta:probe:clis": "node scripts/eval-meta-agents.mjs --probe-clis-only",
    "meta:test:setup": "node --test tests/setup/*.test.mjs",
    "meta:test:meta-theory": "node --test tests/meta-theory/*.test.mjs",
    "meta:graphify:check": "node scripts/graphify-cli.mjs check",
    "meta:graphify:install": "node scripts/graphify-cli.mjs install",
    "meta:graphify:update": "node scripts/graphify-cli.mjs update",
    "meta:validate": "node scripts/validate-project.mjs",
    "meta:check": "npm run meta:check:runtimes && npm run meta:validate",
    "meta:verify:all": "npm run meta:check && npm run meta:check:global && node scripts/eval-meta-agents.mjs --require-all-runtimes && npm run meta:test:setup && npm run meta:test:meta-theory",
    "meta:verify:all:live": "npm run meta:check && npm run meta:check:global && node scripts/eval-meta-agents.mjs --require-all-runtimes --live && npm run meta:test:setup && npm run meta:test:meta-theory",
    "meta:setup:install": "node setup.mjs",
    "meta:setup:update": "node setup.mjs --update",
    "meta:setup:check": "node setup.mjs --check"
  },
  "keywords": [
    "claude-code",
    "openclaw",
    "codex",
    "agents",
    "prompt-pack"
  ],
  "author": "KimYx0207",
  "license": "MIT",
  "bin": {
    "meta-kim": "./bin/meta-kim.mjs"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^3.25.76"
  }
}
