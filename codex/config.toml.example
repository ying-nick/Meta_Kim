# Copy this file to ~/.codex/config.toml and replace REPLACE_WITH_REPO_ROOT
# with the absolute path to this repository.
#
# Project custom agents are auto-loaded from:
#   REPLACE_WITH_REPO_ROOT/.codex/agents/
# Project skills are auto-discovered from:
#   REPLACE_WITH_REPO_ROOT/.agents/skills/

model = "gpt-5.4"
model_reasoning_effort = "medium"
approval_policy = "on-request"
sandbox_mode = "workspace-write"

[agents]
max_threads = 6
max_depth = 1

[mcp_servers.meta_kim_runtime]
command = "node"
args = ["REPLACE_WITH_REPO_ROOT/scripts/mcp/meta-runtime-server.mjs"]
